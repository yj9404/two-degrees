# 운영 환경(Railway, Render 등)에서는
# 각 플랫폼의 환경변수 설정 화면에서 아래 값을 입력해주세요.

# PostgreSQL (Neon, Supabase 등 무료 호스팅)
DATABASE_URL=postgresql://user:password@hostname/dbname?sslmode=require

# 관리자 정보
JWT_SECRET=아무거나_긴_랜덤_문자열_32자_이상
GOOGLE_CLIENT_ID=your_google_client_id
ALLOWED_ADMIN_EMAILS=email1@gmail.com,email2@gmail.com

# S3 / Cloudflare R2 오브젝트 스토리지 설정
# Cloudflare R2 사용 시: AWS_REGION=auto, S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# AWS S3 사용 시: AWS_REGION=ap-northeast-2, S3_ENDPOINT_URL 항목 삭제
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=auto
S3_BUCKET_NAME=your_bucket_name
S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
S3_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# [프로덕션] Vertex AI 설정 (GCP Cloud Run → 후불 청구, aiplatform.googleapis.com)
# Cloud Run 서비스 계정에 "Vertex AI 사용자" IAM 역할을 부여하면 ADC 자동 인증됩니다.
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# [로컬 개발] AI Studio API Key (GOOGLE_CLOUD_PROJECT 미설정 시 폴백)
# Vertex AI 설정이 있는 경우 이 값은 무시됩니다.
GEMINI_API_KEY=your_gemini_api_key_here

# Cloud Scheduler 전용 시크릿 (GCP Cloud Scheduler → X-Scheduler-Secret 헤더 값과 동일하게 설정)
SCHEDULER_SECRET=your_random_secret_here
